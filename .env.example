# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_MODE=polling # or webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
# Shared secret used by the bot service to call backend endpoints
# (/me, /kyes/:id GET, /me/notification-settings) on behalf of a Telegram user.
# Backend honors `X-Service-Token` + `X-Service-Telegram-Id`.
SERVICE_TOKEN=

# TON
TON_NETWORK=testnet
TON_FACTORY_ADDRESS=
TON_API_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
TON_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# TMA / public
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BOT_USERNAME=roosta_bot
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL=http://localhost:3000/tonconnect-manifest.json

# Backend
PORT=3001
NODE_ENV=development
